{
  "title": "MX Master 3 Host Switch",
  "rules": [
    {
      "description": "Cmd+Opt+1/2/3 → Switch MX Master 3 to host 1/2/3",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "1",
            "modifiers": {
              "mandatory": ["left_command", "left_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "~/workspace/dotfiles/mouse-switch/SwitchMouse.app/Contents/MacOS/switch_mouse_wrapper 1"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "2",
            "modifiers": {
              "mandatory": ["left_command", "left_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "~/workspace/dotfiles/mouse-switch/SwitchMouse.app/Contents/MacOS/switch_mouse_wrapper 2"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "3",
            "modifiers": {
              "mandatory": ["left_command", "left_option"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "~/workspace/dotfiles/mouse-switch/SwitchMouse.app/Contents/MacOS/switch_mouse_wrapper 3"
            }
          ]
        }
      ]
    }
  ]
}
