[core]
	editor = nano
	excludesfile = ~/.gitignore_global
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[alias]
	st = status
	co = checkout
	br = branch
	lg = log --oneline --graph --decorate --all
	unstage = reset HEAD --

[color]
	ui = auto
[user]
	email = ducommun.mark@gmail.com
	name = Mark Ducommun
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
